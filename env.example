# ─── Cloudflare (obrigatório para deploy) ────────────────────────
# Obtenha em: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=seu_api_token_aqui

# Obtenha em: https://dash.cloudflare.com/ (lado direito da tela)
CLOUDFLARE_ACCOUNT_ID=seu_account_id_aqui

# ─── IDs dos recursos D1 (gerados ao criar via wrangler) ─────────
# wrangler d1 create siscr-shared-staging
D1_SHARED_STAGING_ID=placeholder

# wrangler d1 create siscr-shared-production
D1_SHARED_PRODUCTION_ID=placeholder

# ─── IDs dos recursos KV ─────────────────────────────────────────
# wrangler kv namespace create KV_SESSIONS --preview
KV_SESSIONS_STAGING_ID=placeholder
KV_TENANT_CACHE_STAGING_ID=placeholder

# ─── Stripe ──────────────────────────────────────────────────────
# Modo TESTE — use as chaves sk_test_* e pk_test_*
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Auth ────────────────────────────────────────────────────────
# String aleatória longa — use: openssl rand -base64 32
BETTER_AUTH_SECRET=sua_chave_secreta_aqui

# ─── Variáveis de ambiente da API (staging) ──────────────────────
# Configuradas automaticamente pelo wrangler.toml
# Não precisam estar neste arquivo — são injetadas via [vars] no wrangler.toml
# Secrets sensíveis: definir via "wrangler secret put NOME --env staging"
