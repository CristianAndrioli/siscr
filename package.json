{
  "name": "siscr",
  "version": "0.0.0",
  "private": true,
  "description": "ERP SaaS Multi-Tenant — Cloudflare Workers + D1 + Pages",
  "scripts": {
    "dev": "turbo run dev",
    "dev:api": "turbo run dev --filter=@siscr/api",
    "dev:web": "turbo run dev --filter=@siscr/web",
    "build": "turbo run build",
    "deploy:staging": "turbo run deploy:staging",
    "db:migrate:staging": "pnpm --filter=@siscr/api run db:migrate:shared:remote",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "turbo": "^2.5.0"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0"
}
